# Sample environment configuration for hybrid‑rag
# Copy this file to ``.env`` and edit the values as needed.

# URL of the local Ollama server (default works if you run ``ollama serve``)
OLLAMA_HOST=http://localhost:11434

# Name of the Ollama embedding model – you can list available models with ``ollama list``
EMBEDDING_MODEL=nomic-embed-text

# Name of the LLM model used for generation
LLM_MODEL=phi3

# Directory where the FAISS index will be stored (relative to project root is fine)
FAISS_INDEX_PATH=faiss_index

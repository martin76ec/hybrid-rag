# Sample environment configuration for hybrid‑rag
# Copy this file to ``.env`` and edit the values as needed.

# URL of the local Ollama server (default works if you run ``ollama serve``)
OLLAMA_HOST=http://localhost:11434

# Name of the Ollama embedding model – you can list available models with ``ollama list``
EMBEDDING_MODEL=nomic-embed-text

# Name of the LLM model used for generation
LLM_MODEL=llama3.2

# Directory where the FAISS index will be stored (relative to project root is fine)
FAISS_INDEX_PATH=faiss_index

# Directory where the knowledge graph will be stored
GRAPH_STORE_PATH=graph_store

# Max retry attempts for transient Ollama errors (502, 503, 429, timeouts)
OLLAMA_MAX_RETRIES=3

# Max simultaneous in-flight Ollama requests (Ollama typically handles ~3)
OLLAMA_MAX_CONCURRENCY=3

# LLM response cache directory (stores /api/generate responses on disk)
# Set to empty string to disable caching entirely
OLLAMA_CACHE_DIR=llm_cache
